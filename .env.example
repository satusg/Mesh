# ──────────────────────────────────────────────────────────────
# Backend
# ──────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5174

# License signing secret (any long random string)
LICENSE_SECRET=change_me_to_a_long_random_secret_string

# Mesh credentials
MESH_CLIENT_ID=your_mesh_client_id
MESH_CLIENT_SECRET=your_mesh_client_secret

# Mesh transfer configuration
MESH_RECEIVING_ADDRESS=0x0000000000000000000000000000000000000000
MESH_NETWORK_ID=e3c7fdd8-b1fc-4e51-85ae-bb276e075611
MESH_ASSET_SYMBOL=USDC

# ──────────────────────────────────────────────────────────────
# Frontend  (prefix all with VITE_ so Vite exposes them)
# ──────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_MESH_CLIENT_ID=your_mesh_client_id
VITE_PRODUCT_ID=a1b2c3d4-0000-0000-0000-000000000001
